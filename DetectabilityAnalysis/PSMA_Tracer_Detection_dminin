# FIGURE HELPERS
# ══════════════════════════════════════════════════════════════════════════════

def make_ax(gs_pos, title, xlabel="", ylabel=""):
    """Create and style one axes panel."""
    ax = fig.add_subplot(gs_pos)
    ax.set_facecolor(AX)
    ax.tick_params(colors=TXT, labelsize=9)
    ax.set_title(title, color=TXT, fontsize=10.5, pad=9,
                 fontweight="semibold", loc="left")
    ax.set_xlabel(xlabel, color=DIM, fontsize=9, labelpad=5)
    ax.set_ylabel(ylabel, color=DIM, fontsize=9, labelpad=5)
    ax.grid(True, alpha=0.13, color=GRID, linewidth=0.65)
    for sp in ax.spines.values():
        sp.set_edgecolor("#1b2635")
        sp.set_linewidth(0.7)
    return ax


def idc_zone_shading(ax):
    """Shade IDC anatomy zones as translucent colour bands."""
    ax.axvspan(0,    a["p05"], color="#D32F2F", alpha=0.10, zorder=0)
    ax.axvspan(a["p05"], a["p10"], color="#F57F17", alpha=0.10, zorder=0)
    ax.axvspan(a["p10"], a["p25"], color="#F5C400", alpha=0.10, zorder=0)
    ax.axvspan(a["p25"], a["p50"], color="#2E7D32", alpha=0.07, zorder=0)


def idc_vlines(ax):
    """Vertical reference lines at PET/MRI p10, p25, and median."""
    ax.axvline(a["p10"], color="#D32F2F", ls=":",  lw=1.3, alpha=0.75, zorder=1)
    ax.axvline(a["p25"], color="#F5C400", ls="--", lw=1.3, alpha=0.65, zorder=1)
    ax.axvline(a["p50"], color="#546E7A", ls="-",  lw=1.0, alpha=0.45, zorder=1)


def zone_labels(ax):
    """Small anatomy zone text labels along the x-axis baseline."""
    for x, txt, col in [
        (a["p05"] / 2,                       "PSMA\nfloor",        "#D32F2F"),
        ((a["p05"] + a["p10"]) / 2,          "MRI-\noccult","#F57F17"),
        ((a["p10"] + a["p25"]) / 2,          "early\nclinical", "#F5C400"),
        ((a["p25"] + a["p50"]) / 2,          "index\nlesion", "#2E7D32"),
    ]:
        ax.text(x, 0.03, txt, ha="center", color=col, fontsize=7.5,
                alpha=0.90, transform=ax.get_xaxis_transform())


def rose_hlines(ax):
    """Horizontal Rose-criterion threshold lines."""
    ax.axhline(ROSE_POSSIBLE, color="#F5C400", ls="--", lw=1.5,
               label=f"Rose possible  SNR ≥ {ROSE_POSSIBLE:.0f}")
    ax.axhline(ROSE_RELIABLE, color="#2E7D32", ls="--", lw=1.5,
               label=f"Rose reliable  SNR ≥ {ROSE_RELIABLE:.0f}")


def leg(**kw):
    """Common legend keyword arguments."""
    return dict(fontsize=7.5, facecolor="#ffffff", labelcolor=TXT,
                framealpha=0.92, edgecolor="#ccd3da", **kw)


# ══════════════════════════════════════════════════════════════════════════════
# GENERATE CURVES — 6-panel figure
# ══════════════════════════════════════════════════════════════════════════════

def generate_curves(cohort_df, anchors):
    """Build and save the 6-panel detectability curve figure."""
    global fig, a
    a = anchors   # make anchors accessible to helper functions

    # Pre-compute IDC diameters array for coverage calculations
    idc_d = cohort_df["lesion_diameter_mm"].values

    # ── Figure layout ──────────────────────────────────────────────────────
    fig = plt.figure(figsize=(22, 15), facecolor=BG)
    fig.suptitle(
        "PET/MRI Prostate Cancer — PSMA Tracer Detectability Curves\n"
        "STEP 1: PSMA PET/MRI Lesion Cohort (n=751)   ·   "
        "STEP 2: 6 Literature PSMA Scenarios   ·   "
        "STEP 3: Gaussian PSF  +  Rose SNR Criterion",
        fontsize=12.5, color=TXT, fontweight="bold", y=0.998,
    )
    gs = gridspec.GridSpec(
        2, 3,
        hspace=0.44, wspace=0.30,
        left=0.055, right=0.975, top=0.932, bottom=0.065,
    )

    # ── PANEL A — RC(d) curves ─────────────────────────────────────────────
    #
    # Shows the Gaussian PSF partial volume effect.
    # Each curve corresponds to one literature FWHM value (STEP 2 → STEP 3).
    # PET/MRI anatomy zones (STEP 1) are overlaid as shaded bands.
    #
    ax_a = make_ax(
        gs[0, 0],
        "A  │  Recovery Coefficient  RC\u2083D(d)\n"
        "    STEP 3 · Gaussian PSF partial-volume effect per literature FWHM",
        "Lesion Diameter  d  (mm)",
        "Recovery Coefficient  RC\u2083D(d)",
    )
    idc_zone_shading(ax_a)
    idc_vlines(ax_a)
    zone_labels(ax_a)

    for lbl, tracer, fwhm, lbr, nf, _, _ in PSMA_STUDIES:
        fwhm_eff_a = np.sqrt(fwhm**2 + FWHM_MOTION**2)
        ax_a.plot(
            D_RANGE, rc_3d(D_RANGE, fwhm_eff_a),
            color=TRACER_COLORS[tracer],
            lw=2.2, ls=TRACER_LS[tracer], alpha=0.88,
            label=f"{lbl}  FWHM_eff={fwhm_eff_a:.1f} mm",
        )

    ax_a.axhline(0.5, color="#90A4AE", ls=":", lw=1.2, label="RC = 0.5")
    ax_a.axhline(0.9, color="#546E7A", ls=":", lw=1.0, label="RC = 0.9")
    ax_a.set_xlim(1, 14)
    ax_a.set_ylim(0, 1.06)

    # IDC anchor annotations on right edge
    for d_ref, lbl_ref, c_ref in [
        (a["p10"], f"PET/MRI p10\n{a['p10']:.1f}mm",    "#D32F2F"),
        (a["p25"], f"PET/MRI p25\n{a['p25']:.1f}mm",    "#F5C400"),
        (a["p50"], f"PET/MRI med\n{a['p50']:.1f}mm",    "#546E7A"),
    ]:
        ax_a.annotate(
            lbl_ref,
            xy=(d_ref, 0.98), xytext=(d_ref + 0.3, 0.88),
            color=c_ref, fontsize=7, ha="left",
            arrowprops=dict(arrowstyle="-", color=c_ref, lw=0.7),
        )

    ax_a.legend(**leg(loc="lower right"))

    # ── PANEL B — SNR(d) curves ────────────────────────────────────────────
    #
    # SNR(d) = (LBR−1)·RC(d)/noise  for each literature scenario.
    # Rose thresholds (SNR≥3, SNR≥5) mark the detection boundaries.
    # PET/MRI anatomy zones (STEP 1) shaded; filled area above SNR≥5.
    #
    ax_b = make_ax(
        gs[0, 1],
        "B  │  Signal-to-Noise Ratio  SNR(d)\n"
        "    STEP 3 · Rose thresholds · PET/MRI anatomy zones (STEP 1)",
        "Lesion Diameter  d  (mm)",
        "SNR(d)",
    )
    idc_zone_shading(ax_b)
    idc_vlines(ax_b)
    rose_hlines(ax_b)

    for lbl, tracer, fwhm, lbr, nf, _, _ in PSMA_STUDIES:
        snr_arr = snr(D_RANGE, fwhm, lbr, nf)
        dr = dmin(fwhm, lbr, nf, ROSE_RELIABLE)
        ax_b.plot(
            D_RANGE, snr_arr,
            color=TRACER_COLORS[tracer],
            lw=2.2, ls=TRACER_LS[tracer], alpha=0.88,
            label=f"{lbl}  (d_min={dr:.1f}mm)",
        )
        ax_b.fill_between(
            D_RANGE, ROSE_RELIABLE, snr_arr,
            where=snr_arr >= ROSE_RELIABLE,
            color=TRACER_COLORS[tracer], alpha=0.07,
        )

    # Mark d_min reliable crossings with vertical ticks
    for lbl, tracer, fwhm, lbr, nf, _, _ in PSMA_STUDIES:
        dr = dmin(fwhm, lbr, nf, ROSE_RELIABLE)
        if not np.isnan(dr):
            ax_b.axvline(dr, color=TRACER_COLORS[tracer],
                         ls=":", lw=1.0, alpha=0.55)
            ax_b.text(dr + 0.15, 42, f"d_min={dr:.1f}mm",
                      ha="left", va="top", fontsize=7.0,
                      color=TRACER_COLORS[tracer], rotation=90, fontweight="bold")
    ax_b.set_xlim(1, 14)
    ax_b.set_ylim(0, 50)
    ax_b.text(13.7, ROSE_POSSIBLE + 0.8, "possible",
              color="#F5C400", fontsize=7.5, ha="right")
    ax_b.text(13.7, ROSE_RELIABLE + 0.8, "reliable",
              color="#2E7D32", fontsize=7.5, ha="right")
    ax_b.legend(**leg(loc="upper left"))

    # ── PANEL C — d_min vs FWHM parametric sweep ──────────────────────────
    #
    # Shows how d_min_reliable degrades as scanner resolution worsens.
    # Each curve = one LBR value drawn from the PSMA literature range (STEP 2).
    # Shaded band between possible and reliable thresholds.
    # Scatter dots = actual (FWHM, d_min) for each literature study (STEP 2→3).
    # Horizontal dashed lines = PET/MRI anatomy anchors (STEP 1).
    #
    ax_c = make_ax(
        gs[0, 2],
        "C  │  Min. Detectable Diameter  vs  FWHM\n"
        "    STEP 3 · LBR sweep · dots = literature (STEP 2) · IDC tiers (STEP 1)",
        "PET Resolution  FWHM  (mm)",
        "d_min  (mm)",
    )

    fwhm_sw  = np.linspace(2.0, 7.0, 300)
    LBR_VALS = [3.0, 3.5, 4.0, 4.5]
    NF_VALS  = [0.05, 0.05, 0.04, 0.04]
    LBR_COLS = ["#FFF9C4", "#FFF176", "#F5C400", "#F57F17"]

    for lbr_v, nf_v, col in zip(LBR_VALS, NF_VALS, LBR_COLS):
        dr_sw = [dmin(f, lbr_v, nf_v, ROSE_RELIABLE) for f in fwhm_sw]
        dp_sw = [dmin(f, lbr_v, nf_v, ROSE_POSSIBLE) for f in fwhm_sw]
        ax_c.plot(fwhm_sw, dr_sw, color=col, lw=2.2,
                  label=f"LBR = {lbr_v}  (reliable)")
        ax_c.fill_between(fwhm_sw, dp_sw, dr_sw, color=col, alpha=0.12)

    # Literature operating points (STEP 2 → STEP 3)
    for lbl, tracer, fwhm, lbr, nf, _, _ in PSMA_STUDIES:
        dr = dmin(fwhm, lbr, nf, ROSE_RELIABLE)
        ax_c.scatter(
            [fwhm], [dr],
            color=TRACER_COLORS[tracer], s=70,
            zorder=6, edgecolors="#333333", linewidths=0.8,
        )
        ax_c.annotate(
            lbl, xy=(fwhm, dr),
            xytext=(fwhm + 0.1, dr + 0.15),
            color=TRACER_COLORS[tracer], fontsize=6.5,
        )

    # IDC anatomy reference lines (STEP 1)
    for d_ref, lbl_ref, c_ref in [
        (a["p10"], f"PET/MRI p10 = {a['p10']:.1f} mm", "#D32F2F"),
        (a["p25"], f"PET/MRI p25 = {a['p25']:.1f} mm", "#F5C400"),
        (a["p50"], f"PET/MRI med = {a['p50']:.1f} mm",  "#546E7A"),
    ]:
        ax_c.axhline(d_ref, color=c_ref, ls=":", lw=1.0, alpha=0.65, label=lbl_ref)

    ax_c.set_xlim(2, 7)
    ax_c.set_ylim(0, 9)
    ax_c.text(6.9, 0.10, "shaded = possible → reliable",
              ha="right", color=DIM, fontsize=7.5)
    ax_c.legend(fontsize=7, facecolor="#ffffff", labelcolor=TXT,
                framealpha=0.92, edgecolor="#ccd3da", loc="upper left")

    # ── PANEL D — SNR heat-map ─────────────────────────────────────────────
    #
    # Each cell: SNR(d_anchor) for one PSMA study × one IDC anatomy diameter.
    # Rows  = PSMA literature scenarios (STEP 2).
    # Cols  = IDC anatomy anchor diameters (STEP 1).
    # Green box = Rose reliable (SNR ≥ 5).
    #
    ax_d = make_ax(
        gs[1, 0],
        "D  │  SNR Heat-Map\n"
        "    STEP 2 scenarios × STEP 1 PET/MRI anatomy anchors\n"
        "    Green outline = Rose reliable (SNR ≥ 5)",
        "", "",
    )

    HM_KEYS   = ["p05", "p10", "p25", "pirads4", "p50", "gs_high", "p75"]
    HM_LABELS = [
        f"PET/MRI p05\n{a['p05']:.1f}mm",
        f"PET/MRI p10\n{a['p10']:.1f}mm",
        f"PET/MRI p25\n{a['p25']:.1f}mm",
        f"PI-RADS4\n{a['pirads4']:.1f}mm",
        f"PET/MRI med\n{a['p50']:.1f}mm",
        f"GS≥8\n{a['gs_high']:.1f}mm",
        f"PET/MRI p75\n{a['p75']:.1f}mm",
    ]

    snr_mat = np.array([
        [snr(a[k], fwhm, lbr, nf) for k in HM_KEYS]
        for (_, _, fwhm, lbr, nf, _, _) in PSMA_STUDIES
    ])

    cmap_hm = mcolors.LinearSegmentedColormap.from_list(
        "psma_snr",
        ["#E3F2FD", "#90CAF9", "#42A5F5", "#1565C0",
         "#0D47A1", "#1A237E", "#0D1B5E", "#050D3A"],
        N=256,
    )
    im = ax_d.imshow(snr_mat, cmap=cmap_hm, aspect="auto",
                     vmin=0, vmax=90, interpolation="nearest")

    ax_d.set_xticks(range(len(HM_LABELS)))
    ax_d.set_xticklabels(HM_LABELS, color=TXT, fontsize=8)
    ax_d.set_yticks(range(len(PSMA_STUDIES)))
    ax_d.set_yticklabels([s[0] for s in PSMA_STUDIES], color=TXT, fontsize=9)

    for i in range(snr_mat.shape[0]):
        for j in range(snr_mat.shape[1]):
            v = snr_mat[i, j]
            ax_d.text(j, i, f"{v:.0f}",
                      ha="center", va="center",
                      color="white" if v > 45 else TXT,
                      fontsize=9, fontweight="bold")
            if v >= ROSE_RELIABLE:
                ax_d.add_patch(plt.Rectangle(
                    (j - 0.48, i - 0.48), 0.96, 0.96,
                    fill=False, edgecolor="#2E7D32", lw=1.5, alpha=0.80,
                ))

    cb = fig.colorbar(im, ax=ax_d, fraction=0.04, pad=0.02)
    cb.ax.tick_params(colors=TXT, labelsize=8)
    cb.set_label("SNR", color=TXT, fontsize=8)
    cb.ax.axhline(ROSE_RELIABLE, color="#2E7D32", lw=1.5)
    cb.ax.axhline(ROSE_POSSIBLE, color="#F5C400", lw=1.2, ls="--")

    # ── PANEL E — d_min vs noise % ────────────────────────────────────────
    #
    # Shows detection-limit sensitivity to background noise level.
    # Solid curve = ROSE_RELIABLE; faded fill down to ROSE_POSSIBLE.
    # Dots = each study's published noise operating point (STEP 2).
    # PET/MRI anatomy anchors from STEP 1 as horizontal reference lines.
    #
    ax_e = make_ax(
        gs[1, 1],
        "E  │  Detection Limit  vs  Background Noise\n"
        "    STEP 3 sensitivity analysis · dots = published noise (STEP 2)",
        "Background Noise Fraction  (%)",
        "d_min  (mm)",
    )

    nf_sw = np.linspace(0.02, 0.10, 300)

    for lbl, tracer, fwhm, lbr, nf_lit, _, _ in PSMA_STUDIES:
        dr_arr = [dmin(fwhm, lbr, n, ROSE_RELIABLE) for n in nf_sw]
        dp_arr = [dmin(fwhm, lbr, n, ROSE_POSSIBLE) for n in nf_sw]
        ax_e.plot(
            nf_sw * 100, dr_arr,
            color=TRACER_COLORS[tracer], lw=2.2,
            ls=TRACER_LS[tracer], alpha=0.88,
            label=f"{lbl}  LBR={lbr}",
        )
        ax_e.fill_between(nf_sw * 100, dp_arr, dr_arr,
                          color=TRACER_COLORS[tracer], alpha=0.07)
        # Published noise operating point
        dr_act = dmin(fwhm, lbr, nf_lit, ROSE_RELIABLE)
        ax_e.scatter(
            [nf_lit * 100], [dr_act],
            color=TRACER_COLORS[tracer], s=70, zorder=6,
            edgecolors="#333333", linewidths=0.8,
        )

    for d_ref, lbl_ref, c_ref in [
        (a["p10"], f"PET/MRI p10 = {a['p10']:.1f} mm", "#D32F2F"),
        (a["p25"], f"PET/MRI p25 = {a['p25']:.1f} mm", "#F5C400"),
    ]:
        ax_e.axhline(d_ref, color=c_ref, ls=":", lw=1.0, alpha=0.75, label=lbl_ref)

    ax_e.set_xlim(2, 10)
    ax_e.set_ylim(0, 5.5)
    ax_e.text(9.85, 0.12, "● = published noise level",
              ha="right", color=DIM, fontsize=8)
    ax_e.legend(**leg(loc="upper left"))

    # ── PANEL F — Ranked d_min bar chart ──────────────────────────────────
    #
    # All 6 scenarios sorted by d_min_reliable (ascending).
    # Solid bar  = reliable detection limit (SNR ≥ 5).
    # Faded bar  = possible detection limit (SNR ≥ 3).
    # Annotation = d_min value + percentage of PET/MRI cohort detectable (STEP 1).
    # Vertical lines = PET/MRI p10 and p25 anatomy anchors.
    #
    ax_f = make_ax(
        gs[1, 2],
        "F  │  Ranked  Min. Detectable Diameter\n"
        "    Solid = reliable (SNR≥5)  ·  Faded = possible (SNR≥3)\n"
        "    % = PET/MRI cohort coverage (STEP 1)",
        "Min. Detectable Diameter  (mm)",
        "",
    )

    bar_rows = []
    for lbl, tracer, fwhm, lbr, nf, _, _ in PSMA_STUDIES:
        dr  = dmin(fwhm, lbr, nf, ROSE_RELIABLE)
        dp  = dmin(fwhm, lbr, nf, ROSE_POSSIBLE)
        cov = (idc_d >= dr).mean() * 100
        bar_rows.append((lbl, tracer, fwhm, lbr, nf, dr, dp, cov))

    bar_rows.sort(key=lambda x: x[5])   # ascending d_min reliable
    y_pos = np.arange(len(bar_rows))

    for i, (lbl, tracer, fwhm, lbr, nf, dr, dp, cov) in enumerate(bar_rows):
        col = TRACER_COLORS[tracer]
        ax_f.barh(i, dr, color=col, height=0.55, alpha=0.95, zorder=3)
        ax_f.barh(i, dp, color=col, height=0.55, alpha=0.28, zorder=2)
        ax_f.text(dr + 0.08, i,
                  f"{dr:.1f} mm   ({cov:.0f}% cov.)",
                  va="center", color=TXT, fontsize=8.5)

    ax_f.set_yticks(y_pos)
    ax_f.set_yticklabels([r[0] for r in bar_rows], color=TXT, fontsize=9)

    ax_f.axvline(a["p10"], color="#D32F2F", ls=":", lw=1.4, alpha=0.8,
                 label=f"PET/MRI p10 = {a['p10']:.1f} mm")
    ax_f.axvline(a["p25"], color="#F5C400", ls="--", lw=1.4, alpha=0.8,
                 label=f"PET/MRI p25 = {a['p25']:.1f} mm")
    # x-limit: accommodate all d_min reliable values + label space
    all_dr = [dmin(fwhm, lbr, nf, ROSE_RELIABLE) for _, _, fwhm, lbr, nf, _, _ in PSMA_STUDIES]
    ax_f.set_xlim(0, max([v for v in all_dr if not np.isnan(v)]) * 1.40)

    tracer_patches = [mpatches.Patch(color=v, label=k)
                      for k, v in TRACER_COLORS.items()]
    leg_t = ax_f.legend(handles=tracer_patches, fontsize=8,
                         facecolor="#0e1520", labelcolor=TXT,
                         framealpha=0.92, edgecolor="#1b2635",
                         title="Tracer", title_fontsize=8, loc="lower right")
    ax_f.add_artist(leg_t)
    ax_f.legend(**leg(loc="upper right"))

    # ── Save ─────────────────────────────────────────────────────────────
    plt.savefig(OUTPUT_FILE, dpi=OUTPUT_DPI, bbox_inches="tight",
                facecolor=fig.get_facecolor())
    print(f"\n[STEP 4] Figure saved → {OUTPUT_FILE}")
    plt.close(fig)


