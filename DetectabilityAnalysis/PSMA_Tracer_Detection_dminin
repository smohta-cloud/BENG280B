# CONSOLE REPORT
# ══════════════════════════════════════════════════════════════════════════════

def print_report(cohort_df, anchors):
    idc_d = cohort_df["lesion_diameter_mm"].values
    W = 68

    print(f"\n{'─' * W}")
    print("  STEP 1 Results — IDC Anatomy Anchors")
    print(f"{'─' * W}")
    tier_map = [
        ("Occult zone      d < p05",    f"< {anchors['p05']:.1f} mm"),
        ("Sub-clinical     d < p10",    f"< {anchors['p10']:.1f} mm"),
        ("Early-detect     p10–p25",    f"{anchors['p10']:.1f} – {anchors['p25']:.1f} mm"),
        ("Index lesion     p25–p50",    f"{anchors['p25']:.1f} – {anchors['p50']:.1f} mm"),
        ("Bulky lesion     ≥ p75",      f"≥ {anchors['p75']:.1f} mm"),
        ("PI-RADS 4 median",            f"{anchors['pirads4']:.1f} mm"),
        ("PI-RADS 5 median",            f"{anchors['pirads5']:.1f} mm"),
        ("Gleason ≥ 8 median",          f"{anchors['gs_high']:.1f} mm"),
    ]
    for lbl, val in tier_map:
        print(f"  {lbl:<32s}: {val}")

    print(f"\n{'─' * W}")
    print("  STEP 2 — Literature PSMA Parameters")
    print(f"{'─' * W}")
    print(f"  {'Study':<18}  {'Tracer':<14}  {'FWHM':>5}  {'σ':>6}  "
          f"{'LBR':>4}  {'noise':>5}  PMID")
    print("  " + "─" * 62)
    for lbl, tracer, fwhm, lbr, nf, pmid, journal in PSMA_STUDIES:
        print(f"  {lbl:<18}  {tracer:<14}  {fwhm:>4.1f}mm  "
              f"{sigma(fwhm):>5.2f}mm  {lbr:>4.1f}  {nf*100:>4.0f}%  {pmid}")

    print(f"\n{'─' * W}")
    print("  STEP 3 — PET Physics Model — Detection Limits")
    print(f"{'─' * W}")
    print(f"  {'Study':<18}  {'Tracer':<14}  {'d_min poss':>10}  "
          f"{'d_min rel':>9}  {'PET/MRI tier':<28}  {'Cov':>7}")
    print("  " + "─" * 95)
    for lbl, tracer, fwhm, lbr, nf, pmid, _ in PSMA_STUDIES:
        dp  = dmin(fwhm, lbr, nf, ROSE_POSSIBLE)
        dr  = dmin(fwhm, lbr, nf, ROSE_RELIABLE)
        cov = (idc_d >= dr).mean() * 100
        if   dr < anchors["p05"]: tier = f"PSMA floor (<{anchors['p05']:.1f}mm)"
        elif dr < anchors["p10"]: tier = f"MRI-occult (<{anchors['p10']:.1f}mm)"
        elif dr < anchors["p25"]: tier = f"Early-clinical ({anchors['p10']:.1f}-{anchors['p25']:.1f}mm)"
        else:                     tier = f"Index lesion"
        print(f"  {lbl:<18}  {tracer:<14}  {dp:>8.2f}mm  {dr:>7.2f}mm  "
              f"{tier:<28}  {cov:>6.1f}%")


