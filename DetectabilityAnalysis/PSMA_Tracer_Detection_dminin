# MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    print("\n" + "═" * 68)
    print("  PET/MRI Prostate — PSMA Detectability Curve Generator")
    print("  STEP 1: IDC MRI Cohort  ·  STEP 2: Literature PSMA Studies")
    print("  STEP 3: PET Physics     ·  STEP 4: 6-Panel Curve Figure")
    print("═" * 68)

    # STEP 1 — build PET/MRI cohort and extract anatomy anchors
    print("\n[STEP 1] Building PSMA PET/MRI lesion cohort …")
    cohort_df = build_idc_cohort(use_live=USE_LIVE_IDC)
    anchors   = extract_anchors(cohort_df)
    print(f"         Cohort: n={len(cohort_df)} · "
          f"median lesion {cohort_df['lesion_diameter_mm'].median():.1f} mm · "
          f"IQR {cohort_df['lesion_diameter_mm'].quantile(0.25):.1f}–"
          f"{cohort_df['lesion_diameter_mm'].quantile(0.75):.1f} mm")

    # STEP 2 — literature parameters (pre-defined in PSMA_STUDIES table)
    print(f"\n[STEP 2] {len(PSMA_STUDIES)} literature PSMA scenarios loaded.")
    for lbl, tracer, fwhm, lbr, nf, pmid, journal in PSMA_STUDIES:
        print(f"         {lbl:<18}  {tracer:<14}  FWHM={fwhm}mm  "
              f"LBR={lbr}  noise={nf*100:.0f}%  PMID {pmid}")

    # STEP 3 — PET physics + STEP 4 — curves
    print(f"\n[STEP 3] Running PET physics model …")
    print(f"         FWHM_eff = sqrt(FWHM^2 + {FWHM_MOTION}^2 mm^2)  ·  RC_3D = erf(d/2sqrt(2)sigma_eff)^3")
    print(f"         SNR = (LBR·RC_3D - 1) · (d/FWHM_eff)^1.5 / {NOISE_CLINICAL:.2f}  ·  Rose >=3/>=5")
    print(f"         [motion blur {FWHM_MOTION}mm FWHM  +  clinical noise CoV {NOISE_CLINICAL*100:.0f}%]")

    print(f"\n[STEP 4] Generating 6-panel figure …")
    generate_curves(cohort_df, anchors)

    # Console report
    print_report(cohort_df, anchors)

    print(f"\n{'─' * 68}")
    print(f"  Done.  Output → {OUTPUT_FILE}")
    print(f"{'─' * 68}\n")


if __name__ == "__main__":
    main()
